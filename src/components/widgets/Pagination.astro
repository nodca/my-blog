---
import { t } from "@config";
import type { PaginationProps } from "@interfaces/data";

const { page, totalPages, baseUrl } = Astro.props as PaginationProps;

// Simple pagination logic for editorial style
const prevUrl = page.url.prev;
const nextUrl = page.url.next;
---

<nav class="flex items-center justify-between w-full text-sm font-medium py-4" aria-label="Pagination">
  <div class="flex-1 text-left">
    {prevUrl ? (
      <a 
        href={prevUrl} 
        class="inline-flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors group"
      >
        <span class="group-hover:-translate-x-1 transition-transform">&larr;</span> 
        {t("label.prevPage") || "Newer"}
      </a>
    ) : (
      <span class="inline-flex items-center gap-2 text-base-content/20 cursor-not-allowed">
        &larr; {t("label.prevPage") || "Newer"}
      </span>
    )}
  </div>

  <div class="flex-1 text-center font-mono text-base-content/40 tracking-widest text-xs">
    {page.current} / {totalPages}
  </div>

  <div class="flex-1 text-right">
    {nextUrl ? (
      <a 
        href={nextUrl} 
        class="inline-flex items-center justify-end gap-2 text-base-content/60 hover:text-base-content transition-colors group"
      >
        {t("label.nextPage") || "Older"}
        <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
      </a>
    ) : (
      <span class="inline-flex items-center justify-end gap-2 text-base-content/20 cursor-not-allowed">
        {t("label.nextPage") || "Older"} &rarr;
      </span>
    )}
  </div>
</nav>
