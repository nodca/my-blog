---
import BaseLayout from "@/layouts/BaseLayout.astro";

const isIndexed = false;
const title = "评论管理";
const description = "博客评论审核与管理";
---

<BaseLayout title={title} description={description} isIndexed={isIndexed}>
  <div class="mx-auto w-full max-w-6xl space-y-8 px-4 py-8">
    <section id="login-panel" class="mx-auto max-w-md">
      <div class="card border border-base-content/10 bg-base-200 shadow-xl">
        <div class="card-body">
          <h1 class="card-title text-2xl">评论管理</h1>
          <p class="text-sm text-base-content/60">
            输入评论管理令牌后，可审核、标记垃圾评论和删除评论。
          </p>

          <label class="form-control mt-4">
            <span class="mb-2 text-sm font-medium text-base-content/70">
              管理令牌
            </span>
            <input
              id="admin-token"
              type="password"
              autocomplete="current-password"
              class="input input-bordered w-full"
              placeholder="COMMENT_ADMIN_TOKEN"
            />
          </label>

          <div id="login-error" class="mt-3 min-h-5 text-sm text-error"></div>

          <div class="card-actions mt-4 justify-end">
            <button id="login-button" class="btn btn-primary">登录</button>
          </div>
        </div>
      </div>
    </section>

    <section id="admin-panel" class="hidden space-y-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div>
          <h1 class="text-3xl font-serif font-bold text-base-content">评论管理</h1>
          <p class="text-sm text-base-content/60">
            审核、筛选并处理博客评论。
          </p>
        </div>

        <div class="flex gap-2">
          <button id="refresh-button" class="btn btn-ghost">刷新</button>
          <button id="logout-button" class="btn btn-outline">退出</button>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-4">
        <div class="rounded-[1.75rem] border border-base-content/10 bg-base-200 p-5">
          <div class="text-sm text-base-content/50">总评论</div>
          <div id="count-total" class="mt-2 text-3xl font-semibold text-base-content">-</div>
        </div>
        <div class="rounded-[1.75rem] border border-base-content/10 bg-base-200 p-5">
          <div class="text-sm text-base-content/50">待审核</div>
          <div id="count-pending" class="mt-2 text-3xl font-semibold text-warning">-</div>
        </div>
        <div class="rounded-[1.75rem] border border-base-content/10 bg-base-200 p-5">
          <div class="text-sm text-base-content/50">已通过</div>
          <div id="count-approved" class="mt-2 text-3xl font-semibold text-success">-</div>
        </div>
        <div class="rounded-[1.75rem] border border-base-content/10 bg-base-200 p-5">
          <div class="text-sm text-base-content/50">垃圾评论</div>
          <div id="count-spam" class="mt-2 text-3xl font-semibold text-error">-</div>
        </div>
      </div>

      <div class="grid gap-6 xl:grid-cols-[1.5fr_1fr]">
        <section class="rounded-[1.75rem] border border-base-content/10 bg-base-200 p-5">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <h2 class="text-xl font-semibold text-base-content">评论列表</h2>
            <div class="flex flex-col gap-3 md:flex-row">
              <select id="status-filter" class="select select-bordered">
                <option value="all">全部状态</option>
                <option value="pending">待审核</option>
                <option value="approved">已通过</option>
                <option value="spam">垃圾评论</option>
              </select>
              <input
                id="search-input"
                type="text"
                class="input input-bordered"
                placeholder="搜索 slug / 昵称 / 内容"
              />
            </div>
          </div>

          <div id="comment-feedback" class="mt-3 min-h-5 text-sm text-base-content/60"></div>

          <div class="mt-4 overflow-x-auto">
            <table class="table">
              <thead>
                <tr>
                  <th>文章</th>
                  <th>作者</th>
                  <th>内容</th>
                  <th>状态</th>
                  <th>时间</th>
                  <th class="text-right">操作</th>
                </tr>
              </thead>
              <tbody id="comment-table-body"></tbody>
            </table>
          </div>
        </section>

        <section class="rounded-[1.75rem] border border-base-content/10 bg-base-200 p-5">
          <h2 class="text-xl font-semibold text-base-content">热门文章</h2>
          <p class="mt-1 text-sm text-base-content/60">
            按已通过评论数量排序。
          </p>

          <div class="mt-4 overflow-x-auto">
            <table class="table">
              <thead>
                <tr>
                  <th>文章</th>
                  <th class="text-right">评论</th>
                </tr>
              </thead>
              <tbody id="top-pages-body"></tbody>
            </table>
          </div>
        </section>
      </div>
    </section>
  </div>

  <script is:inline>
    var SESSION_KEY = "blog_comment_admin_token";

    function getCommentApiBase() {
      var host = window.location.hostname;
      var protocol = window.location.protocol;

      if (host === "localhost" || host === "127.0.0.1") {
        return protocol + "//" + host + ":4322/api/comments";
      }

      return window.location.origin + "/api/comments";
    }

    function getToken() {
      return sessionStorage.getItem(SESSION_KEY) || "";
    }

    function setToken(token) {
      sessionStorage.setItem(SESSION_KEY, token);
    }

    function clearToken() {
      sessionStorage.removeItem(SESSION_KEY);
    }

    async function apiFetch(path, options) {
      var response = await fetch(
        getCommentApiBase() + path,
        Object.assign(
          {
            headers: Object.assign(
              {
                Authorization: "Bearer " + getToken(),
              },
              options && options.headers ? options.headers : {}
            ),
          },
          options || {}
        )
      );

      if (response.status === 401) {
        clearToken();
        showLogin();
        throw new Error("登录已失效");
      }

      var data = await response.json();
      if (!response.ok) {
        throw new Error(data.message || "请求失败");
      }

      return data;
    }

    function formatDate(value) {
      return new Date(value).toLocaleString("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      });
    }

    function showLogin(message) {
      document.getElementById("login-panel").classList.remove("hidden");
      document.getElementById("admin-panel").classList.add("hidden");
      document.getElementById("login-error").textContent = message || "";
    }

    function showAdmin() {
      document.getElementById("login-panel").classList.add("hidden");
      document.getElementById("admin-panel").classList.remove("hidden");
      document.getElementById("login-error").textContent = "";
    }

    function renderSummary(summary) {
      document.getElementById("count-total").textContent = summary.counts.total;
      document.getElementById("count-pending").textContent = summary.counts.pending;
      document.getElementById("count-approved").textContent = summary.counts.approved;
      document.getElementById("count-spam").textContent = summary.counts.spam;

      var topPagesBody = document.getElementById("top-pages-body");
      topPagesBody.innerHTML = "";

      if (!summary.topPages.length) {
        var emptyRow = document.createElement("tr");
        var cell = document.createElement("td");
        cell.colSpan = 2;
        cell.className = "py-6 text-center text-sm text-base-content/50";
        cell.textContent = "暂无已通过评论";
        emptyRow.appendChild(cell);
        topPagesBody.appendChild(emptyRow);
        return;
      }

      summary.topPages.forEach(function(page) {
        var row = document.createElement("tr");

        var titleCell = document.createElement("td");
        var titleDiv = document.createElement("div");
        titleDiv.className = "font-medium text-base-content";
        titleDiv.textContent = page.page_title || page.slug;

        var slugDiv = document.createElement("div");
        slugDiv.className = "text-xs text-base-content/50";
        slugDiv.textContent = page.slug;

        titleCell.appendChild(titleDiv);
        titleCell.appendChild(slugDiv);

        var countCell = document.createElement("td");
        countCell.className = "text-right font-mono";
        countCell.textContent = String(page.total);

        row.appendChild(titleCell);
        row.appendChild(countCell);
        topPagesBody.appendChild(row);
      });
    }

    function actionButton(label, className, handler) {
      var button = document.createElement("button");
      button.type = "button";
      button.className = className;
      button.textContent = label;
      button.addEventListener("click", handler);
      return button;
    }

    async function moderateComment(id, action) {
      await apiFetch("/admin/moderate", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ id: id, action: action }),
      });
    }

    function renderComments(result) {
      var feedback = document.getElementById("comment-feedback");
      var body = document.getElementById("comment-table-body");
      body.innerHTML = "";
      feedback.textContent = "共 " + result.total + " 条";

      if (!result.comments.length) {
        var emptyRow = document.createElement("tr");
        var cell = document.createElement("td");
        cell.colSpan = 6;
        cell.className = "py-8 text-center text-sm text-base-content/50";
        cell.textContent = "没有匹配的评论";
        emptyRow.appendChild(cell);
        body.appendChild(emptyRow);
        return;
      }

      result.comments.forEach(function(comment) {
        var row = document.createElement("tr");

        var slugCell = document.createElement("td");
        var titleDiv = document.createElement("div");
        titleDiv.className = "font-medium text-base-content";
        titleDiv.textContent = comment.pageTitle || comment.slug;
        var slugDiv = document.createElement("div");
        slugDiv.className = "text-xs text-base-content/50";
        slugDiv.textContent = comment.slug;
        slugCell.appendChild(titleDiv);
        slugCell.appendChild(slugDiv);

        var authorCell = document.createElement("td");
        var authorDiv = document.createElement("div");
        authorDiv.className = "font-medium";
        authorDiv.textContent = comment.author;
        authorCell.appendChild(authorDiv);
        if (comment.email) {
          var emailDiv = document.createElement("div");
          emailDiv.className = "text-xs text-base-content/50";
          emailDiv.textContent = comment.email;
          authorCell.appendChild(emailDiv);
        }

        var contentCell = document.createElement("td");
        contentCell.className =
          "max-w-md whitespace-pre-wrap break-words text-sm leading-6";
        contentCell.textContent = comment.content;

        var statusCell = document.createElement("td");
        var badge = document.createElement("span");
        badge.className = "badge";
        if (comment.status === "approved") badge.classList.add("badge-success");
        if (comment.status === "pending") badge.classList.add("badge-warning");
        if (comment.status === "spam") badge.classList.add("badge-error");
        badge.textContent = comment.status;
        statusCell.appendChild(badge);

        var timeCell = document.createElement("td");
        timeCell.className = "text-sm text-base-content/60";
        timeCell.textContent = formatDate(comment.createdAt);

        var actionCell = document.createElement("td");
        actionCell.className = "text-right";
        var actionGroup = document.createElement("div");
        actionGroup.className = "flex justify-end gap-2";

        if (comment.status !== "approved") {
          actionGroup.appendChild(
            actionButton("通过", "btn btn-success btn-xs", async function() {
              await moderateComment(comment.id, "approve");
              await refreshAdminData();
            })
          );
        }

        if (comment.status !== "pending") {
          actionGroup.appendChild(
            actionButton("待审", "btn btn-warning btn-xs", async function() {
              await moderateComment(comment.id, "pending");
              await refreshAdminData();
            })
          );
        }

        if (comment.status !== "spam") {
          actionGroup.appendChild(
            actionButton("垃圾", "btn btn-error btn-xs", async function() {
              await moderateComment(comment.id, "spam");
              await refreshAdminData();
            })
          );
        }

        actionGroup.appendChild(
          actionButton("删除", "btn btn-ghost btn-xs", async function() {
            if (!window.confirm("确认删除这条评论？")) return;
            await moderateComment(comment.id, "delete");
            await refreshAdminData();
          })
        );

        actionCell.appendChild(actionGroup);

        row.appendChild(slugCell);
        row.appendChild(authorCell);
        row.appendChild(contentCell);
        row.appendChild(statusCell);
        row.appendChild(timeCell);
        row.appendChild(actionCell);
        body.appendChild(row);
      });
    }

    async function refreshAdminData() {
      var feedback = document.getElementById("comment-feedback");
      feedback.textContent = "正在加载...";

      try {
        var status = document.getElementById("status-filter").value;
        var query = document.getElementById("search-input").value.trim();

        var summary = await apiFetch("/admin/summary");
        renderSummary(summary);

        var list = await apiFetch(
          "/admin/list?status=" +
            encodeURIComponent(status) +
            "&q=" +
            encodeURIComponent(query)
        );
        renderComments(list);
      } catch (error) {
        feedback.textContent = error.message || "加载失败";
      }
    }

    async function tryLogin() {
      var token = document.getElementById("admin-token").value.trim();
      if (!token) {
        showLogin("请输入管理令牌");
        return;
      }

      setToken(token);

      try {
        await apiFetch("/admin/summary");
        showAdmin();
        await refreshAdminData();
      } catch (error) {
        clearToken();
        showLogin(error.message || "登录失败");
      }
    }

    function initAdminPage() {
      var pageRoot = document.getElementById("admin-panel");
      if (pageRoot.dataset.bound === "true") return;
      pageRoot.dataset.bound = "true";

      document.getElementById("login-button").addEventListener("click", tryLogin);
      document.getElementById("admin-token").addEventListener("keydown", function(event) {
        if (event.key === "Enter") {
          tryLogin();
        }
      });
      document.getElementById("refresh-button").addEventListener("click", refreshAdminData);
      document.getElementById("logout-button").addEventListener("click", function() {
        clearToken();
        showLogin();
      });
      document.getElementById("status-filter").addEventListener("change", refreshAdminData);
      document.getElementById("search-input").addEventListener("change", refreshAdminData);

      if (getToken()) {
        showAdmin();
        refreshAdminData().catch(function() {
          showLogin("管理令牌已失效");
        });
      } else {
        showLogin();
      }
    }

    document.addEventListener("DOMContentLoaded", initAdminPage);
    document.addEventListener("astro:page-load", initAdminPage);
  </script>
</BaseLayout>
