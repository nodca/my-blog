---
import Pagination from "@components/widgets/Pagination.astro";
import { t } from "@config";
import type { Page, Post } from "@interfaces/data";
import BaseLayout from "@layouts/BaseLayout.astro";
import { generatePageLinks } from "@utils/blogUtils";
import dayjs from "@utils/dayjs";
import { getTagPaginationPaths } from "@utils/paginationUtils";
import { Icon } from "astro-icon/components";
import EditorialPostListItem from "@/components/EditorialPostListItem.astro";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return getTagPaginationPaths({ paginate });
}

const { page } = Astro.props as { page: Page };
const params = Astro.params as { tag: string; page: string };

const totalPages = Math.ceil(page.total / page.size);
const pageLinks = generatePageLinks(totalPages);
---

<BaseLayout title={`${t("label.tagPage")} - ${params.tag}`}>
  <div class="max-w-3xl mx-auto py-12 md:py-20 antialiased">
    <header class="mb-16">
      <div class="border-b border-base-content/10 pb-8">
        <div
          class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
        >
          <div class="flex flex-wrap items-center gap-3">
            <Icon name="lucide:tag" class="h-6 w-6 text-pepper" />
            <h1
              id="h1"
              class="text-4xl font-extrabold tracking-tight text-base-content md:text-5xl"
            >
              {params.tag}
            </h1>
            <span
              class="font-mono text-xs uppercase tracking-[0.16em] text-base-content/50"
            >
              {page.total}
              {page.total === 1 ? t("label.post") : t("label.posts")}
            </span>
          </div>

          <div class="flex flex-wrap items-center gap-6 text-sm font-medium">
            <a
              href="/blog/tags"
              class="text-base-content/60 transition-colors hover:text-pepper"
            >
              {t("label.allTags")}
            </a>
            <a
              href="/blog"
              class="text-base-content/60 transition-colors hover:text-pepper"
            >
              {t("label.backToBlog")}
            </a>
          </div>
        </div>

        <p class="mt-6 text-sm text-base-content/60">
          {t("label.tagDescription")}
        </p>
      </div>
    </header>

    <div class="mb-16 flex flex-col gap-5">
      {
        page.data.map((blog: Post) => (
          <EditorialPostListItem
            href={`/blog/${blog.slug}`}
            title={blog.data.title}
            description={blog.data.description}
            displayDate={dayjs(blog.data.pubDate).format("YYYY.MM.DD")}
            category={blog.data.categories?.[0]}
            readingTime={blog.remarkPluginFrontmatter?.readingTime}
          />
        ))
      }
    </div>

    <div class="border-t border-base-content/10 pt-8">
      <Pagination
        page={page}
        totalPages={totalPages}
        pageLinks={pageLinks}
        baseUrl={`/blog/tag/${params.tag}`}
      />
    </div>
  </div>
</BaseLayout>
