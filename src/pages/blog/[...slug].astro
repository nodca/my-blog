---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection } from "astro:content";
import Comment from "@components/widgets/Comment.astro";
import License from "@components/widgets/License.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import dayjs from "@utils/dayjs";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((blog: { slug: any }) => ({
    params: { slug: blog.slug },
    props: { blog },
  }));
}
interface Props {
  blog: CollectionEntry<"blog">;
}

const { blog } = Astro.props;
const { Content, remarkPluginFrontmatter } = await blog.render();
const displayDate = blog.data.pubDate
  ? dayjs(blog.data.pubDate).format("YYYY.MM.DD")
  : "";
const image = new URL(`/og/${blog.slug}.png`, Astro.site).toString();
const url = new URL(`/blog/${blog.slug}`, Astro.url.origin);
---

<BaseLayout
  title={blog.data.title}
  description={blog.data.description}
  image={image}
>
  <article class="max-w-3xl mx-auto py-12 md:py-20 antialiased w-full">
    
    <!-- Editorial Post Header -->
    <header class="mb-14 md:mb-20">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-base-content mb-8 font-serif leading-[1.15]">
        {blog.data.title}
      </h1>
      
      {blog.data.description && (
        <p class="text-xl md:text-2xl text-base-content/60 font-medium leading-relaxed mb-8">
          {blog.data.description}
        </p>
      )}

      <!-- Minimalist Meta Information -->
      <div class="flex flex-wrap items-center gap-4 text-sm font-mono text-base-content/50 border-t border-base-content/10 pt-6">
        <time datetime={blog.data.pubDate.toISOString()}>
          {displayDate}
        </time>
        
        {remarkPluginFrontmatter?.readingTime && (
          <>
            <span class="opacity-40">&bull;</span>
            <span>{remarkPluginFrontmatter.readingTime}</span>
          </>
        )}
        
        {blog.data.categories?.length > 0 && (
          <>
            <span class="opacity-40">&bull;</span>
            <span class="uppercase tracking-widest">{blog.data.categories[0]}</span>
          </>
        )}
      </div>
    </header>

    <!-- Hero Image (if exists) -->
    {blog.data.image && (
      <figure class="mb-16 -mx-6 sm:mx-0">
        <Image 
          src={blog.data.image} 
          alt={blog.data.title} 
          width={1200} 
          height={630} 
          class="w-full h-auto object-cover sm:rounded-lg"
          loading="eager"
        />
      </figure>
    )}

    <!-- Prose Content -->
    <div 
      id="content" 
      class="prose prose-lg md:prose-xl max-w-none prose-headings:font-serif prose-headings:font-bold prose-headings:tracking-tight prose-a:font-medium prose-a:underline-offset-4 prose-a:decoration-1 hover:prose-a:decoration-2 prose-blockquote:border-l-base-content/20 prose-blockquote:text-base-content/70 prose-blockquote:font-serif prose-blockquote:italic prose-img:rounded-lg prose-img:w-full mb-24"
    >
      <Content />
    </div>

    <!-- Article Footer (Tags & License) -->
    <footer class="border-t border-base-content/10 pt-10 mt-10">
      {blog.data.tags?.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          <span class="text-sm font-medium text-base-content/40 uppercase tracking-widest mr-2">Tags:</span>
          {blog.data.tags.map((tag: string) => (
            <a href={`/blog/tags#${tag}`} class="text-sm font-mono text-base-content/60 hover:text-base-content transition-colors underline decoration-1 underline-offset-4">
              #{tag}
            </a>
          ))}
        </div>
      )}

      <License
        url={url}
        title={blog.data.title}
        image={blog.data.image}
        pubDate={blog.data.pubDate}
        badge={blog.data.badge}
        categories={blog.data.categories}
        tags={blog.data.tags}
        word={remarkPluginFrontmatter.totalCharCount}
        time={remarkPluginFrontmatter.readingTime}
      />
      
      <div class="mt-16">
        <Comment />
      </div>
    </footer>
    
  </article>
</BaseLayout>
