---
import Pagination from "@components/widgets/Pagination.astro";
import { t } from "@config";
import type { Page, Post } from "@interfaces/data";
import BaseLayout from "@layouts/BaseLayout.astro";
import { generatePageLinks } from "@utils/blogUtils";
import dayjs from "@utils/dayjs";
import { getMainBlogPaginationPaths } from "@utils/paginationUtils";
import EditorialPostListItem from "@/components/EditorialPostListItem.astro";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return getMainBlogPaginationPaths({ paginate });
}

const { page }: { page: Page } = Astro.props;

const totalPages = Math.ceil(page.total / page.size);
const pageLinks = generatePageLinks(totalPages);
---

<BaseLayout title={t("nav.blog") || "Blog"}>
  <div class="max-w-3xl mx-auto py-12 md:py-20 antialiased">
    <!-- Editorial Header -->
    <header class="mb-16">
      <h1
        class="text-4xl md:text-5xl font-extrabold tracking-tight text-base-content mb-6 font-serif"
      >
        {t("nav.blog") || "Articles"}
      </h1>
      <p class="text-lg text-base-content/60 font-medium max-w-2xl">
        All entries, thoughts, and writings.
      </p>

      <!-- Minimalist Sub-navigation -->
      <nav
        class="flex flex-wrap items-center gap-6 mt-10 text-sm font-medium border-t border-base-content/10 pt-6"
      >
        <a
          href="/blog/archives"
          class="text-base-content/60 transition-colors hover:text-pepper"
          >归档</a
        >
        <a
          href="/blog/categories"
          class="text-base-content/60 transition-colors hover:text-pepper"
          >分类</a
        >
        <a
          href="/blog/tags"
          class="text-base-content/60 transition-colors hover:text-pepper"
          >标签</a
        >
        <a
          href="/blog/search"
          class="text-base-content/60 transition-colors hover:text-pepper"
          >搜索</a
        >
      </nav>
    </header>

    <div class="flex flex-col gap-5 mb-16">
      {
        page.data.map((blog: Post) => (
          <EditorialPostListItem
            href={`/blog/${blog.slug}`}
            title={blog.data.title}
            description={blog.data.description}
            displayDate={dayjs(blog.data.pubDate).format("YYYY.MM.DD")}
            category={blog.data.categories?.[0]}
            readingTime={blog.remarkPluginFrontmatter?.readingTime}
          />
        ))
      }
    </div>

    <!-- Pagination -->
    <div class="border-t border-base-content/10 pt-8">
      <Pagination
        page={page}
        totalPages={totalPages}
        pageLinks={pageLinks}
        baseUrl={`/blog`}
      />
    </div>
  </div>
</BaseLayout>
