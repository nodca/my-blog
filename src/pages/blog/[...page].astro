---
import Pagination from "@components/widgets/Pagination.astro";
import { t } from "@config";
import type { Page, Post } from "@interfaces/data";
import BaseLayout from "@layouts/BaseLayout.astro";
import { generatePageLinks } from "@utils/blogUtils";
import dayjs from "@utils/dayjs";
import { getMainBlogPaginationPaths } from "@utils/paginationUtils";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return getMainBlogPaginationPaths({ paginate });
}

const { page }: { page: Page } = Astro.props;

const totalPages = Math.ceil(page.total / page.size);
const pageLinks = generatePageLinks(totalPages);
---

<BaseLayout title={t("nav.blog") || "Blog"}>
  <div class="max-w-3xl mx-auto py-12 md:py-20 antialiased">
    
    <!-- Editorial Header -->
    <header class="mb-16">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-base-content mb-6 font-serif">
        {t("nav.blog") || "Articles"}
      </h1>
      <p class="text-lg text-base-content/60 font-medium max-w-2xl">
        All entries, thoughts, and writings.
      </p>

      <!-- Minimalist Sub-navigation -->
      <nav class="flex flex-wrap items-center gap-6 mt-10 text-sm font-medium border-t border-base-content/10 pt-6">
        <a href="/blog/archives" class="text-base-content/60 hover:text-base-content transition-colors">归档</a>
        <a href="/blog/categories" class="text-base-content/60 hover:text-base-content transition-colors">分类</a>
        <a href="/blog/tags" class="text-base-content/60 hover:text-base-content transition-colors">标签</a>
        <a href="/blog/search" class="text-base-content/60 hover:text-base-content transition-colors">搜索</a>
      </nav>
    </header>

    <!-- Post List: Minimalist List -->
    <div class="flex flex-col mb-16">
      {page.data.map((blog: Post) => (
        <article class="group py-8 border-b border-base-content/10 last:border-0 hover:bg-base-content/[0.02] -mx-4 px-4 sm:mx-0 sm:px-0 sm:hover:bg-transparent transition-colors">
          <a href={`/blog/${blog.slug}`} class="block">
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-3 sm:gap-6">
              <!-- Date column -->
              <time class="text-sm font-mono text-base-content/40 shrink-0 sm:w-28 pt-1">
                {dayjs(blog.data.pubDate).format("YYYY.MM.DD")}
              </time>
              
              <!-- Content column -->
              <div class="flex-1">
                <h2 class="text-2xl font-semibold text-base-content group-hover:text-primary transition-colors mb-3 leading-snug">
                  {blog.data.title}
                </h2>
                {blog.data.description && (
                  <p class="text-base-content/60 leading-relaxed text-base">
                    {blog.data.description}
                  </p>
                )}
                
                {/* Meta details (categories/tags) - simplified */}
                <div class="flex flex-wrap items-center gap-4 mt-4 text-xs font-mono text-base-content/40">
                  {blog.data.categories?.length > 0 && (
                    <span class="flex items-center gap-1.5 uppercase tracking-wider">
                      {blog.data.categories[0]}
                    </span>
                  )}
                  {blog.remarkPluginFrontmatter?.readingTime && (
                    <span class="flex items-center gap-1.5 opacity-70">
                      {blog.remarkPluginFrontmatter.readingTime}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Pagination -->
    <div class="border-t border-base-content/10 pt-8">
      <Pagination page={page} totalPages={totalPages} pageLinks={pageLinks} baseUrl={`/blog`} />
    </div>

  </div>
</BaseLayout>
