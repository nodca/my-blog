---
import { type CollectionEntry, getCollection } from "astro:content";
import { DATE_FORMAT } from "@config";
import dayjs from "@utils/dayjs";
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";

const posts = await getCollection("blog");
const recentPosts = posts
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  )
  .slice(0, 5);
---

<BaseLayout title="首页 - 记录生活与技术的个人博客">
  <div class="max-w-3xl mx-auto py-12 md:py-16">
    <!-- Hero Section: Avant-Garde Pop Art Typography -->
    <header class="mb-24 relative">
      <div class="absolute -left-6 top-3 w-3 h-3 bg-blood hidden sm:block"></div>
      <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-base-content mb-8 leading-[0.9] font-serif uppercase selection:bg-blood selection:text-white">
        你好，<br/> 欢迎光临。
      </h1>
      <p class="text-xl md:text-2xl text-base-content font-bold max-w-2xl leading-relaxed mb-12 selection:bg-blood selection:text-white">
        这里是我的个人数字花园。<br/>记录技术学习、生活感悟和各种折腾的过程。
      </p>
      
      <div class="flex flex-wrap items-center gap-8 text-base font-black tracking-widest uppercase">
        <a href="/blog" class="group flex items-center gap-2 text-base-content hover:text-blood transition-colors">
          <span class="border-b-4 border-base-content group-hover:border-blood pb-0.5 transition-colors">浏览文章</span>
          <Icon name="lucide:arrow-up-right" class="w-6 h-6 transition-transform group-hover:translate-x-1 group-hover:-translate-y-1" />
        </a>
        <a href="/about" class="group flex items-center gap-2 text-base-content hover:text-blood transition-colors">
          <span class="border-b-4 border-base-content/20 group-hover:border-blood pb-0.5 transition-colors">关于我</span>
        </a>
      </div>
    </header>

    <!-- Recent Posts: High Contrast Blueprint List -->
    <section>
      <div class="flex items-end justify-between mb-8 border-b-4 border-base-content pb-4">
        <h2 class="text-2xl md:text-3xl font-black tracking-tighter uppercase text-base-content selection:bg-blood selection:text-white">
          最新文章 / LATEST
        </h2>
        <a href="/blog" class="text-xs font-black tracking-widest uppercase text-base-content hover:bg-blood hover:text-white px-2 py-1 transition-colors mb-1">
          全部文章 &rarr;
        </a>
      </div>

      <div class="flex flex-col border-b-4 border-base-content">
        {recentPosts.map((post: CollectionEntry<"blog">) => (
          <article class="group py-8 border-t-2 border-base-content/30 transition-all duration-200">
            <a href={`/blog/${post.slug}`} class="block px-4 sm:px-0">
              <div class="flex flex-col sm:flex-row sm:items-start gap-4 sm:gap-8">
                <!-- Date column -->
                <time class="text-sm font-black tracking-widest font-mono text-base-content/50 group-hover:text-blood shrink-0 sm:w-32 pt-1 uppercase transition-colors">
                  {dayjs(post.data.pubDate).format("YY.MM.DD")}
                </time>
                
                <!-- Content column -->
                <div class="flex-1">
                  <h3 class="text-2xl md:text-4xl font-black text-base-content group-hover:text-blood transition-colors mb-3 leading-[1.1] tracking-tight font-serif">
                    {post.data.title}
                  </h3>
                  {post.data.description && (
                    <p class="text-base-content/80 leading-relaxed text-lg font-medium transition-colors">
                      {post.data.description}
                    </p>
                  )}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
