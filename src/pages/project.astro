---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Projects">
  <article class="max-w-3xl mx-auto py-16 md:py-24 antialiased">
    
    <header class="mb-16 md:mb-24 text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-base-content mb-8 font-serif leading-[1.1]">
        Projects
      </h1>
      <div class="w-16 h-px bg-base-content/20 mx-auto"></div>
    </header>

    <div class="prose prose-lg md:prose-xl mx-auto text-center prose-p:text-base-content/70 prose-p:leading-relaxed font-serif italic">
      <p>
        "I am still curating this list. Selected works will be showcased here."
      </p>
    </div>

  </article>
</BaseLayout>
